<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ToDoApp.Maui.Views.TodosPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Todos">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Button
            Text="Load Todos"
            Command="{Binding LoadTodosCommand}" />

        <CollectionView ItemsSource="{Binding Todos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,6" CornerRadius="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}" FontSize="18" />
                            <Label Text="{Binding Description}" FontSize="14" />
                            <Label Text="{Binding CreatedAt, StringFormat='Created: {0:yyyy-MM-dd HH:mm}'}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
